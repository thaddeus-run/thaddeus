{
  "name": "@thaddeus.run/watch",
  "version": "0.0.0",
  "description": "Live semantic subscriptions — triggers that fire on meaning (a symbol renamed, a reference added, a definition moved) by diffing semantic-graph snapshots. Pillar 11 (subscriptions slice).",
  "keywords": [
    "live-database",
    "semantic-events",
    "subscriptions",
    "substrate"
  ],
  "homepage": "https://thaddeus.run",
  "bugs": {
    "url": "https://github.com/thaddeus-run/thaddeus/issues"
  },
  "license": "Apache-2.0",
  "author": {
    "name": "thaddeus.run",
    "url": "https://thaddeus.run"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thaddeus-run/thaddeus.git",
    "directory": "packages/watch"
  },
  "files": [
    "dist",
    "LICENSE.md",
    "README.md"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepublishOnly": "moon run watch:prepublish"
  },
  "dependencies": {
    "@thaddeus.run/graph": "workspace:*"
  },
  "devDependencies": {
    "@thaddeus.run/fs": "workspace:*",
    "@thaddeus.run/identity": "workspace:*",
    "@thaddeus.run/log": "workspace:*",
    "@thaddeus.run/store": "workspace:*",
    "@types/bun": "catalog:",
    "@typescript/native-preview": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:"
  }
}
