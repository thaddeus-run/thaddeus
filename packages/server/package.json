{
  "name": "@thaddeus.run/server",
  "version": "0.1.4-alpha",
  "description": "The untrusted API-first remote for Thaddeus: a Bun.serve HTTP server over the durable Platform that verifies, never decrypts, and serves ciphertext.",
  "keywords": [
    "http",
    "remote",
    "server",
    "substrate"
  ],
  "homepage": "https://thaddeus.run",
  "bugs": {
    "url": "https://github.com/thaddeus-run/thaddeus/issues"
  },
  "license": "Apache-2.0",
  "author": {
    "name": "thaddeus.run",
    "url": "https://thaddeus.run"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thaddeus-run/thaddeus.git",
    "directory": "packages/server"
  },
  "files": [
    "dist",
    "LICENSE.md",
    "README.md"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepublishOnly": "moon run server:prepublish"
  },
  "dependencies": {
    "@noble/hashes": "catalog:",
    "@thaddeus.run/agent": "workspace:*",
    "@thaddeus.run/graph": "workspace:*",
    "@thaddeus.run/identity": "workspace:*",
    "@thaddeus.run/log": "workspace:*",
    "@thaddeus.run/platform": "workspace:*",
    "@thaddeus.run/provenance": "workspace:*",
    "@thaddeus.run/reputation": "workspace:*",
    "@thaddeus.run/review": "workspace:*",
    "@thaddeus.run/store": "workspace:*"
  },
  "devDependencies": {
    "@thaddeus.run/fs": "workspace:*",
    "@thaddeus.run/persist": "workspace:*",
    "@types/bun": "catalog:",
    "@typescript/native-preview": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:"
  }
}
