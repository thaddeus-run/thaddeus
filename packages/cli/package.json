{
  "name": "@thaddeus.run/cli",
  "version": "0.1.5-alpha",
  "private": true,
  "description": "The Thaddeus CLI (thaddeus / thad) source — compiled into the distributed binary. The published `@thaddeus.run/cli` on npm is the binary launcher in `npm/thaddeus`, so this workspace package is private.",
  "keywords": [
    "cli",
    "source-control",
    "thaddeus"
  ],
  "homepage": "https://thaddeus.run",
  "bugs": {
    "url": "https://github.com/thaddeus-run/thaddeus/issues"
  },
  "license": "Apache-2.0",
  "author": {
    "name": "thaddeus.run",
    "url": "https://thaddeus.run"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thaddeus-run/thaddeus.git",
    "directory": "packages/cli"
  },
  "bin": {
    "thad": "./dist/bin.js",
    "thaddeus": "./dist/bin.js"
  },
  "files": [
    "dist",
    "LICENSE.md",
    "README.md"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepublishOnly": "moon run cli:prepublish"
  },
  "dependencies": {
    "@thaddeus.run/agent": "workspace:*",
    "@thaddeus.run/client": "workspace:*",
    "@thaddeus.run/fs": "workspace:*",
    "@thaddeus.run/graph": "workspace:*",
    "@thaddeus.run/identity": "workspace:*",
    "@thaddeus.run/log": "workspace:*",
    "@thaddeus.run/persist": "workspace:*",
    "@thaddeus.run/platform": "workspace:*",
    "@thaddeus.run/provenance": "workspace:*",
    "@thaddeus.run/reputation": "workspace:*",
    "@thaddeus.run/review": "workspace:*",
    "@thaddeus.run/server": "workspace:*",
    "@thaddeus.run/store": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "catalog:",
    "@typescript/native-preview": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:"
  }
}
